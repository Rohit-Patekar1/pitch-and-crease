# Postgres connection (Railway auto-injects this on production)
DATABASE_URL="postgresql://user:password@localhost:5432/pitchandcrease?schema=public"

# Admin password — pick something long. The site has one admin user; this is it.
ADMIN_PASSWORD="change-me-to-a-long-random-string"

# Random secret used to sign the admin session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-64-hex-chars"

# Twitter / X (filled in once you have the developer app)
TWITTER_API_KEY=""
TWITTER_API_SECRET=""
TWITTER_ACCESS_TOKEN=""
TWITTER_ACCESS_SECRET=""

# Site config
SITE_NAME="Pitch and Crease"
SITE_URL="http://localhost:3000"
