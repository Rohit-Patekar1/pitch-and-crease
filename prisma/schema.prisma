// Pitch and Crease — database schema
// Single Article model serves both football and cricket content.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id            String    @id @default(cuid())
  slug          String    @unique
  sport         Sport
  title         String
  dek           String    @db.Text
  body          String    @db.Text       // HTML fragment with embedded SVG + scoped <style>
  status        Status    @default(DRAFT)
  scheduledFor  DateTime?
  publishedAt   DateTime?
  // Social copies — generation script fills these
  twitterThread String?   @db.Text       // newline-separated tweets
  facebookCopy  String?   @db.Text
  // Posted-to-social tracking
  tweetIds      String?   @db.Text       // comma-separated tweet IDs after posting
  tweetedAt     DateTime?
  // Generation metadata
  promptSeed    String?   @db.Text       // the prompt that produced it (for re-runs / audit)
  source        String?                  // "auto-daily" | "manual" | "on-this-day" | etc.
  // SEO
  metaImage     String?                  // path/URL to hero card PNG
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([sport, status])
  @@index([publishedAt])
}

/// A user-submitted prompt waiting for the local Claude Code poller to pick it up.
/// Created by POST /api/generate-request from the admin dashboard.
/// Processed by `npm run process:queue` running on the user's laptop.
model GenerationRequest {
  id            String    @id @default(cuid())
  prompt        String    @db.Text
  slot          String    @default("custom")  // "custom" | "on-this-day" | "recent-match" | etc.
  status        ReqStatus @default(PENDING)
  articleId     String?                       // set when generation succeeds
  errorMessage  String?   @db.Text            // set when generation fails
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, createdAt])
}

enum ReqStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum Sport {
  FOOTBALL
  CRICKET
}

enum Status {
  DRAFT
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}
