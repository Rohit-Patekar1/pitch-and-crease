// Pitch and Crease — database schema
// Single Article model serves both football and cricket content.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Long-form article that lives on the website. When we share it on X, we post
/// ONE promotional tweet (hook + image + article URL), not a thread.
model Article {
  id            String    @id @default(cuid())
  slug          String    @unique
  sport         Sport
  title         String
  dek           String    @db.Text
  body          String    @db.Text       // HTML fragment with embedded SVG + scoped <style>
  status        Status    @default(DRAFT)
  scheduledFor  DateTime?
  publishedAt   DateTime?
  // Social promotional copy
  promoTweet    String?   @db.Text       // single tweet (max ~250 chars, URL appended automatically)
  promoImage    Json?                    // single image: { alt: string, base64: string }
  facebookCopy  String?   @db.Text
  // Posted-to-X tracking
  tweetIds      String?   @db.Text
  tweetedAt     DateTime?
  // Generation metadata
  promptSeed    String?   @db.Text
  source        String?
  // SEO
  metaImage     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([sport, status])
  @@index([publishedAt])
}

/// Twitter-native short content. No website article behind it — lives only on X.
/// Used for "On This Day", quick stat blasts, in-the-moment reactions.
model SocialPost {
  id            String       @id @default(cuid())
  type          SocialType   @default(ON_THIS_DAY)
  sport         Sport
  status        Status       @default(DRAFT)
  /// Internal name so you can find it in the queue (NOT shown on X)
  title         String
  /// 1-3 tweets, separated by blank lines. Same parsing as Article promos.
  tweetText     String       @db.Text
  /// Optional images: [{ slot: number, alt: string, base64: string }]
  /// slot is the tweet index this image attaches to (0 = first tweet)
  tweetImages   Json?
  // Posted-to-X tracking
  tweetIds      String?      @db.Text
  tweetedAt     DateTime?
  scheduledFor  DateTime?
  publishedAt   DateTime?
  // Generation metadata
  promptSeed    String?      @db.Text
  source        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([sport, status])
  @@index([publishedAt])
}

enum SocialType {
  ON_THIS_DAY
  STAT_MOMENT
  QUICK_TAKE
  TRANSFER_FLASH
  OTHER
}

/// A user-submitted prompt waiting for the local Claude Code poller to pick it up.
/// Created by POST /api/generate-request from the admin dashboard.
/// Processed by `npm run process:queue` running on the user's laptop.
model GenerationRequest {
  id            String       @id @default(cuid())
  /// Whether this request should produce a long-form Article or a Twitter-native SocialPost.
  contentType   ContentType  @default(ARTICLE)
  prompt        String       @db.Text
  slot          String       @default("custom")
  status        ReqStatus    @default(PENDING)
  articleId     String?                       // set when an Article is created
  socialPostId  String?                       // set when a SocialPost is created
  errorMessage  String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, createdAt])
}

enum ContentType {
  ARTICLE
  SOCIAL
}

enum ReqStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum Sport {
  FOOTBALL
  CRICKET
}

enum Status {
  DRAFT
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}
